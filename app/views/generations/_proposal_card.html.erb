<%# locals: (proposal:) %>
<div data-controller="proposal-card"
     data-proposal-card-front-value="<%= proposal[:front] %>"
     data-proposal-card-back-value="<%= proposal[:back] %>"
     data-proposal-card-original-front-value="<%= proposal[:front] %>"
     data-proposal-card-original-back-value="<%= proposal[:back] %>"
     data-proposal-card-selected-value="true"
     class="rounded-lg border border-blue-300 dark:border-blue-600 bg-blue-50/50 dark:bg-blue-900/10 p-4 transition-colors">

  <%# ── Display mode ── %>
  <div data-proposal-card-target="display" class="flex items-start gap-3">
    <input type="checkbox"
           checked
           data-action="change->proposal-card#toggle"
           data-proposal-card-target="checkbox"
           class="mt-1 h-4 w-4 rounded border-gray-300 dark:border-gray-600
                  text-blue-600 focus:ring-blue-500 cursor-pointer"
           aria-label="<%= t('generations.new.proposals.select_proposal') %>">
    <div class="flex-1 min-w-0">
      <div class="mb-2">
        <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">
          <%= t("generations.new.proposals.front_label") %>
        </span>
        <p data-proposal-card-target="frontDisplay" class="text-sm text-gray-900 dark:text-gray-100 mt-0.5">
          <%= proposal[:front] %>
        </p>
      </div>
      <div>
        <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">
          <%= t("generations.new.proposals.back_label") %>
        </span>
        <p data-proposal-card-target="backDisplay" class="text-sm text-gray-700 dark:text-gray-300 mt-0.5">
          <%= proposal[:back] %>
        </p>
      </div>
      <span data-proposal-card-target="editedBadge"
            class="hidden mt-2 text-xs bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 px-2 py-0.5 rounded-full">
        <%= t("generations.new.proposals.edited_badge") %>
      </span>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <button data-action="click->proposal-card#startEdit"
              class="text-sm text-blue-600 hover:text-blue-700 dark:text-blue-400 font-medium cursor-pointer">
        <%= t("generations.new.proposals.edit") %>
      </button>
      <button data-action="click->proposal-card#reject"
              class="text-sm text-red-600 hover:text-red-700 dark:text-red-400 font-medium cursor-pointer">
        <%= t("generations.new.proposals.reject") %>
      </button>
    </div>
  </div>

  <%# ── Edit mode (hidden initially) ── %>
  <div data-proposal-card-target="editForm" class="hidden space-y-3">
    <div>
      <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
        <%= t("generations.new.proposals.front_label") %>
      </label>
      <input type="text"
             data-proposal-card-target="frontInput"
             value="<%= proposal[:front] %>"
             maxlength="200"
             class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700
                    text-gray-900 dark:text-gray-100 text-sm px-3 py-2
                    focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
      <p data-proposal-card-target="frontError"
         class="hidden text-xs text-red-600 dark:text-red-400 mt-1"
         role="alert"></p>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">
        <%= t("generations.new.proposals.back_label") %>
      </label>
      <textarea data-proposal-card-target="backInput"
                maxlength="500"
                rows="3"
                class="w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700
                       text-gray-900 dark:text-gray-100 text-sm px-3 py-2
                       focus:ring-2 focus:ring-blue-500 focus:border-blue-500 resize-y"><%= proposal[:back] %></textarea>
      <p data-proposal-card-target="backError"
         class="hidden text-xs text-red-600 dark:text-red-400 mt-1"
         role="alert"></p>
    </div>
    <div class="flex items-center gap-2 justify-end">
      <button data-action="click->proposal-card#cancelEdit"
              class="text-sm text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-200
                     font-medium cursor-pointer px-3 py-1.5">
        <%= t("generations.new.proposals.cancel_edit") %>
      </button>
      <button data-action="click->proposal-card#saveEdit"
              class="text-sm bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-md
                     px-3 py-1.5 cursor-pointer transition-colors">
        <%= t("generations.new.proposals.save_edit") %>
      </button>
    </div>
  </div>
</div>
