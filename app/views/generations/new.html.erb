<% content_for(:title) { t("generations.new.title") } %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto space-y-8">

    <%# ── Page Header ── %>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">
      <%= t("generations.new.title") %>
    </h1>

    <%# ── Status Banner ── %>
    <%= render "generations/status_banner" %>

    <%# ── Source Form + Loader ── %>
    <div data-controller="generation-form"
         data-generation-form-min-length-value="1000"
         data-generation-form-max-length-value="10000">
      <%= render "generations/source_form" %>
      <%= render "generations/generation_loader" %>
    </div>

    <%# ── Proposals Section ── %>
    <%= render "generations/proposals_section" %>

  </div>
</div>
