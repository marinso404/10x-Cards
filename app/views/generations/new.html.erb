<% content_for(:title) { t("generations.new.title") } %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8 px-4 sm:px-6 lg:px-8"
     data-controller="generations-new"
     data-generations-new-min-length-value="1000"
     data-generations-new-max-length-value="10000"
     data-generations-new-generate-url-value="<%= generations_path %>"
     data-generations-new-flashcards-url-value="<%= flashcards_path %>">

  <div class="max-w-3xl mx-auto space-y-8">

    <%# ── Page Header ── %>
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">
      <%= t("generations.new.title") %>
    </h1>

    <%# ── StatusBanner ── %>
    <div data-generations-new-target="statusBanner" class="hidden" role="alert" aria-live="polite">
      <div class="rounded-lg p-4 flex items-start gap-3">
        <span data-generations-new-target="statusIcon" class="shrink-0 mt-0.5"></span>
        <div class="flex-1">
          <p data-generations-new-target="statusTitle" class="font-semibold"></p>
          <p data-generations-new-target="statusBody" class="text-sm mt-1"></p>
          <a data-generations-new-target="statusAction"
             class="hidden text-sm underline mt-2 inline-block font-medium"
             href="#"></a>
        </div>
        <button data-action="click->generations-new#dismissStatus"
                class="shrink-0 text-current opacity-60 hover:opacity-100 cursor-pointer"
                aria-label="Dismiss">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <%# ── SourceTextForm ── %>
    <section class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <form data-action="submit->generations-new#generate">
        <label for="source_text" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
          <%= t("generations.new.source_text.label") %>
        </label>

        <textarea id="source_text"
                  name="source_text"
                  data-generations-new-target="sourceText"
                  data-action="input->generations-new#updateCharCount"
                  required
                  minlength="1000"
                  maxlength="10000"
                  rows="10"
                  placeholder="<%= t('generations.new.source_text.placeholder') %>"
                  class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700
                         text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500
                         px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500
                         disabled:opacity-50 disabled:cursor-not-allowed resize-y"></textarea>

        <div class="flex items-center justify-between mt-2">
          <span data-generations-new-target="charCount"
                class="text-sm text-gray-500 dark:text-gray-400">
            <%= t("generations.new.source_text.hint", count: 0, max: 10_000) %>
          </span>

          <span data-generations-new-target="fieldError"
                class="text-sm text-red-600 dark:text-red-400 hidden"
                role="alert"></span>
        </div>

        <button type="submit"
                data-generations-new-target="submitBtn"
                class="mt-4 inline-flex items-center gap-2 rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold
                       text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500
                       focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
          <svg data-generations-new-target="submitSpinner"
               class="hidden animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <%= t("generations.new.source_text.submit") %>
        </button>
      </form>
    </section>

    <%# ── GenerationLoader ── %>
    <div data-generations-new-target="loader"
         class="hidden"
         role="status"
         aria-live="polite">
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8
                  flex flex-col items-center gap-4 text-center">
        <svg class="animate-spin h-8 w-8 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <p data-generations-new-target="loaderLabel" class="text-sm font-medium text-gray-600 dark:text-gray-400">
          <%= t("generations.new.loader.label") %>
        </p>
      </div>
    </div>

    <%# ── ProposalsList ── %>
    <section data-generations-new-target="proposalsSection" class="hidden space-y-4">

      <%# Proposals header with counters and select all/deselect all %>
      <div class="flex flex-wrap items-center justify-between gap-4">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">
          <%= t("generations.new.proposals.heading") %>
        </h2>
        <div class="flex items-center gap-4 text-sm">
          <span data-generations-new-target="proposalCount" class="text-gray-600 dark:text-gray-400"></span>
          <button data-action="click->generations-new#selectAll"
                  class="text-blue-600 hover:text-blue-700 dark:text-blue-400 font-medium cursor-pointer">
            <%= t("generations.new.proposals.select_all") %>
          </button>
          <button data-action="click->generations-new#deselectAll"
                  class="text-blue-600 hover:text-blue-700 dark:text-blue-400 font-medium cursor-pointer">
            <%= t("generations.new.proposals.deselect_all") %>
          </button>
        </div>
      </div>

      <%# Proposals list container (rendered dynamically by Stimulus) %>
      <div data-generations-new-target="proposalsList" class="space-y-3">
      </div>

      <%# ── BulkActionsBar ── %>
      <div data-generations-new-target="bulkActions"
           class="sticky bottom-0 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700
                  rounded-xl shadow-lg p-4 flex flex-wrap items-center justify-between gap-4">

        <span data-generations-new-target="bulkCount" class="text-sm font-medium text-gray-700 dark:text-gray-300"></span>

        <div class="flex items-center gap-3">
          <button data-action="click->generations-new#discardAll"
                  data-generations-new-target="discardBtn"
                  class="inline-flex items-center gap-2 rounded-lg border border-red-300 dark:border-red-600
                         px-4 py-2 text-sm font-medium text-red-700 dark:text-red-400
                         hover:bg-red-50 dark:hover:bg-red-900/20 focus:outline-none focus:ring-2
                         focus:ring-red-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed
                         transition-colors cursor-pointer">
            <%= t("generations.new.bulk_actions.discard_all") %>
          </button>

          <button data-action="click->generations-new#saveSelected"
                  data-generations-new-target="saveBtn"
                  class="inline-flex items-center gap-2 rounded-lg bg-green-600 px-5 py-2 text-sm font-semibold
                         text-white shadow-sm hover:bg-green-700 focus:outline-none focus:ring-2
                         focus:ring-green-500 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed
                         transition-colors cursor-pointer">
            <svg data-generations-new-target="saveSpinner"
                 class="hidden animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <%= t("generations.new.bulk_actions.save_selected") %>
          </button>
        </div>
      </div>

    </section>

  </div>
</div>
